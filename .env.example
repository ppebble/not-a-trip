# MongoDB
# Required in all environments. Use mongodb+srv:// for hosted production clusters.
MONGODB_URI=mongodb://localhost:27017/not-a-trip
# Optional override. If empty, the database name is derived from MONGODB_URI.
MONGODB_DB=not-a-trip

# Auth.js / NextAuth v5
# Production must use the canonical https:// site URL.
AUTH_URL=http://localhost:3000
# Required. Replace with a strong random value in every non-local environment.
AUTH_SECRET=your-secret-key-here
# Required when running behind a reverse proxy that Auth.js cannot auto-detect.
AUTH_TRUST_HOST=true

# Password breach screening
# Default is enabled and uses the Pwned Passwords k-anonymity range API.
# Set PWNED_PASSWORD_CHECK=off only for isolated local/dev environments.
PWNED_PASSWORD_CHECK=
# If true, signup/password changes fail when the breach API is unavailable.
PWNED_PASSWORD_CHECK_STRICT=false

# Legacy NextAuth aliases are intentionally omitted. Runtime code reads AUTH_* first
# and only keeps NEXTAUTH_* as a temporary deployment fallback.

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# Naver OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# X(Twitter) OAuth
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Google Maps (Places Autocomplete)
# Public browser key. Restrict by HTTP referrer in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Site URL (SEO)
# Production must use the canonical https:// site URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional webhook shared secret for /api/ops/sentry-alert.
SENTRY_WEBHOOK_SECRET=

# Ops alert fan-out (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Web Push (optional; required only when push delivery is enabled)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# Abuse/moderation controls (optional)
NSFW_MODERATION_URL=
ENABLE_DEV_RATE_LIMIT=false

# Local agent MCP helper (optional; not required for production runtime)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
