{
  "steering": {
    "autoInclude": [
      "project-context.md",
      "commit-guidelines.md",
      "task-execution-rules.md",
      "git-workflow.md"
    ],
    "enforceGuidelines": true
  },
  "tasks": {
    "requireIssueLink": true,
    "enforceCommitRules": true,
    "maxCommitSize": 500
  },
  "git": {
    "enforceConventionalCommits": true,
    "requireKoreanDescription": true,
    "maxDescriptionLength": 50,
    "repository": {
      "owner": "ppebble",
      "repo": "not-a-trip",
      "defaultBranch": "develop"
    }
  },
  "mcp": {
    "github": {
      "owner": "ppebble",
      "repo": "not-a-trip",
      "issueTemplateDir": ".github/ISSUE_TEMPLATE/",
      "prTemplate": ".github/PULL_REQUEST_TEMPLATE.md"
    }
  }
}
